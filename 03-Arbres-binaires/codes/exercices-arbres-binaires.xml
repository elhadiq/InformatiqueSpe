</answerpreload><globalextra /><useace /><resultcolumns /><template /><iscombinatortemplate /><allowmultiplestdins /><answer>def recherche(a, x):
    if a is None:
        return False
    if x == a[0]:
        return True
    if x &lt; a[0]:
        return recherche(a[1], x)
    return recherche(a[2], x)
