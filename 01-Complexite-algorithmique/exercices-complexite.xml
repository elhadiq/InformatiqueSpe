        # Completer : comparer liste[m] et x, ajuster g ou d
        ...
    return -1
</answerpreload><globalextra /><useace /><resultcolumns /><template /><iscombinatortemplate /><allowmultiplestdins /><answer>def dichotomie(liste, x):
    g, d = 0, len(liste) - 1
    while g &lt;= d:
        m = (g + d) // 2
        if liste[m] == x:
            return m
        elif liste[m] &lt; x:
            g = m + 1
        else:
            d = m - 1
    return -1
