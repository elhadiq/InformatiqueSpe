&lt;div style="background:#f3f9f9;border:1px solid #b7dadd;border-left:5px solid #026573;border-radius:8px;padding:14px 20px;margin:14px 0;"&gt;
  &lt;pre style="color:#026573;font-family:'Courier New',monospace;font-size:14px;margin:0;background:none;border:none;"&gt;G = {0:[1,2], 1:[0,3], 2:[0,3], 3:[1,2]}
