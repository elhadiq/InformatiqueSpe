</answerpreload><globalextra /><useace /><resultcolumns /><template /><iscombinatortemplate /><allowmultiplestdins /><answer>from collections import deque

def rangs(V0, V1, succ, F):
    V0 = set(V0); V1 = set(V1)
    pred = {}
    for u in succ:
        for v in succ[u]:
            pred.setdefault(v, []).append(u)
    rang = {v: 0 for v in F}
    file = deque(F)
    reste = {u: len(succ.get(u, [])) for u in V1}
    while file:
        v = file.popleft()
        for u in pred.get(v, []):
            if u in rang:
                continue
            if u in V0:
                rang[u] = rang[v] + 1; file.append(u)
            else:
                reste[u] -= 1
                if reste[u] == 0:
                    rang[u] = rang[v] + 1; file.append(u)
    return rang
