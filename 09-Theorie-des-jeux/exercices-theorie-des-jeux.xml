</answerpreload><globalextra /><useace /><resultcolumns /><template /><iscombinatortemplate /><allowmultiplestdins /><answer>def attracteur(V0, V1, succ, F):
    V0 = set(V0); V1 = set(V1)
    pred = {}
    for u in succ:
        for v in succ[u]:
            pred.setdefault(v, []).append(u)
    attr = set(F)
    file = list(F)
    reste = {u: len(succ.get(u, [])) for u in V1}
    while file:
        v = file.pop()
        for u in pred.get(v, []):
            if u in attr:
                continue
            if u in V0:                 # Joueur 0 : un successeur gagnant suffit
                attr.add(u); file.append(u)
            else:                       # Joueur 1 : tous les successeurs gagnants
                reste[u] -= 1
                if reste[u] == 0:
                    attr.add(u); file.append(u)
    return attr
